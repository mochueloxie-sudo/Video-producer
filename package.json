{
  "name": "slide-forge",
  "version": "3.0.0",
  "description": "Turn any document into a polished 1920×1080 presentation — video, PDF, or interactive HTML. 13 themes, 20+ content variants, fully automatic.",
  "main": "executor.js",
  "type": "commonjs",
  "keywords": [
    "video",
    "presentation",
    "slides",
    "pdf",
    "html",
    "feishu",
    "lark",
    "tts",
    "puppeteer",
    "ffmpeg",
    "minimax",
    "llm",
    "ai",
    "agent"
  ],
  "author": "heytea",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mochueloxie-sudo/slide-forge.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "echo '{\"command\":\"all\",\"source\":\"./examples/test_article.md\",\"format\":[\"pdf\",\"html\"],\"output_dir\":\"./output\"}' | node executor.js",
    "test:e2e": "echo '{\"command\":\"all\",\"source\":\"./examples/full_variant_test.md\",\"format\":[\"pdf\",\"html\"],\"output_dir\":\"./test_e2e\"}' | node executor.js",
    "test:step0": "echo '{\"command\":\"step0\",\"source\":\"./examples/test_article.md\",\"output_dir\":\"./test_step0\"}' | node executor.js",
    "test:design": "echo '{\"command\":\"step2\",\"scenes\":\"./test_step0/scenes.json\",\"output_dir\":\"./test_step0\"}' | node executor.js",
    "test:html": "echo '{\"command\":\"step3\",\"scenes\":\"./test_step0/scenes.json\",\"design_params\":\"./test_step0/design_params.json\",\"output_dir\":\"./test_step0\"}' | node executor.js",
    "test:screenshot": "echo '{\"command\":\"step4\",\"html_dir\":\"./test_step0\",\"output_dir\":\"./test_step0/screenshots\"}' | node executor.js",
    "clean": "rm -rf output test_e2e test_step0 test_step1 test_full test_output test_project test_themes debug_html preview"
  },
  "directories": {
    "example": "examples"
  },
  "dependencies": {
    "mammoth": "^1.12.0",
    "marked": "^18.0.0",
    "pdf-parse": "^2.4.5",
    "puppeteer": "^24.40.0"
  }
}
